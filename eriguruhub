    local cont = Instance.new("ScrollingFrame", s); cont.Size = UDim2.new(1, -8, 1, -30); cont.Position = UDim2.new(0, 4, 0, 25); cont.BackgroundTransparency = 1; cont.ScrollBarThickness = 2; cont.CanvasSize = UDim2.new(0,0,0,500)
