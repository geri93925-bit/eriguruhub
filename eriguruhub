local function createSlider(parent, txt, min, max, keyVar)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(1, 0, 0, 38); f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 18); l.Text = txt .. ": " .. string.format("%.1f", _G[keyVar]); l.TextColor3 = Color3.new(0.8,0.8,0.8); l.BackgroundTransparency = 1; l.TextXAlignment = "Left"; l.Font = Enum.Font.SourceSansBold; l.TextSize = 10
    local bg = Instance.new("Frame", f); bg.Size = UDim2.new(1, -10, 0, 5); bg.Position = UDim2.new(0, 5, 0.7, 0); bg.BackgroundColor3 = Color3.fromRGB(30,30,30); bg.BorderSizePixel = 0
    local fill = Instance.new("Frame", bg); fill.Size = UDim2.new((_G[keyVar]-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Color3.fromRGB(0, 150, 255); fill.BorderSizePixel = 0
    bg.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then local c; c = RunService.RenderStepped:Connect(function() if not Uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then c:Disconnect() return end; local r = math.clamp((mouse.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1); _G[keyVar] = min + (max - min) * r; l.Text = txt .. ": " .. string.format("%.1f", _G[keyVar]); fill.Size = UDim2.new(r, 0, 1, 0) end) end end)
end

