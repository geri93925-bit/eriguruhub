-- --- 🎯 統合コアロジック ---
local FovCircle = Drawing.new("Circle")
FovCircle.Thickness = 1; FovCircle.Color = Color3.fromRGB(0, 150, 255)

local function getTarget()
    if _G.PriorityTarget and _G.PriorityTarget.Character and _G.PriorityTarget.Character:FindFirstChild(_G.TargetPart) then return _G.PriorityTarget end
    local t, d = nil, _G.AimFOV
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character and p.Character:FindFirstChild(_G.TargetPart) then
            local pos, on = camera:WorldToViewportPoint(p.Character[_G.TargetPart].Position)
            local dist = (Vector2.new(mouse.X, mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
            if on and dist < d then t = p; d = dist end
        end
    end
    return t
end

RunService.RenderStepped:Connect(function(dt)
    FovCircle.Visible = _G.ShowFOV; FovCircle.Radius = _G.AimFOV; FovCircle.Position = Vector2.new(mouse.X, mouse.Y + 36)
    local char = lp.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local target = getTarget()

    -- 🌪️ FRONT-DIAGONAL RAGE (前側から暴れる)
    if isRecalling and rageEnabled and target and target.Character then
        local head = target.Character:FindFirstChild("Head")
        local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
        if head and tRoot then
            root.Velocity = Vector3.zero
            local angle = tick() * (_G.RageSpeed / 10)
            
            -- 前方(LookVector)と横方向を算出
            local forward = tRoot.CFrame.LookVector
            local side = tRoot.CFrame.RightVector
            
            -- 🛠️ 敵の前方に陣取り、左右に激しく揺れる
            local shake = math.sin(angle) * _G.RageRadius
            local offset = (forward * _G.RageRadius) + (side * shake)
            local finalPos = head.Position + offset + Vector3.new(0, _G.RageHeight, 0)
            
            root.CFrame = CFrame.new(finalPos, head.Position)
            
            -- ロックオン
            local p, on = camera:WorldToViewportPoint(head.Position)
            if on then mousemoverel((p.X - mouse.X), (p.Y - (mouse.Y + 36))) end
            return 
        end
    end

    -- ULTRA GERI AIM (頭部完全固定)
    if (aimOn or _G.GeriMode) and Uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) and target and target.Character then
        local head = target.Character:FindFirstChild("Head")
        if head then
            local p, on = camera:WorldToViewportPoint(head.Position + (head.Velocity * 0.14))
            if on then
                local str = _G.GeriMode and 1 or _G.AimStrength
                mousemoverel((p.X - mouse.X) / str, (p.Y - (mouse.Y + 36)) / str)
            end
        end
    end

    -- FLY & ESP
    if flyOn then
        root.Velocity = Vector3.zero; local dir = Vector3.zero
        if Uis:IsKeyDown(Enum.KeyCode.W) then dir += camera.CFrame.LookVector end
        if Uis:IsKeyDown(Enum.KeyCode.S) then dir -= camera.CFrame.LookVector end
        if Uis:IsKeyDown(Enum.KeyCode.A) then dir -= camera.CFrame.RightVector end
        if Uis:IsKeyDown(Enum.KeyCode.D) then dir += camera.CFrame.RightVector end
        if dir.Magnitude > 0 then root.CFrame += (dir.Unit * _G.FlySpeed * dt) end
    end
    if espOn then
        for _, p in pairs(Players:GetPlayers()) do 
            if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                if not espHolders[p] then 
                    espHolders[p] = { b = Drawing.new("Square"), t = Drawing.new("Text") }
                    espHolders[p].b.Thickness = 1; espHolders[p].t.Size = 12; espHolders[p].t.Center = true; espHolders[p].t.Outline = true 
                end
                local d = espHolders[p]; local v, on = camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                if on then 
                    d.b.Visible = true; d.t.Visible = true; local sX, sY = 2000/v.Z, 3000/v.Z
                    d.b.Size = Vector2.new(sX, sY); d.b.Position = Vector2.new(v.X - sX/2, v.Y - sY/2)
                    d.t.Text = p.DisplayName; d.t.Position = Vector2.new(v.X, v.Y - sY/2 - 14)
                    d.b.Color = Color3.fromRGB(0, 150, 255); d.t.Color = Color3.new(1,1,1) 
                else d.b.Visible = false; d.t.Visible = false end
            elseif espHolders[p] then espHolders[p].b.Visible = false; espHolders[p].t.Visible = false end
        end
    else for _, d in pairs(espHolders) do d.b.Visible = false; d.t.Visible = false end end
end)

