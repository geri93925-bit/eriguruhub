    local b = Instance.new("TextButton", f); b.Size = UDim2.new(0, 16, 0, 16); b.Position = UDim2.new(0, 5, 0.2, 0); b.Text = ""; b.BackgroundColor3 = startValue and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(35,35,35); b.BorderSizePixel = 0
    local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, -30, 1, 0); l.Position = UDim2.new(0, 30, 0, 0); l.Text = txt; l.TextColor3 = Color3.new(0.9,0.9,0.9); l.BackgroundTransparency = 1; l.TextXAlignment = "Left"; l.Font = Enum.Font.SourceSansBold; l.TextSize = 11
